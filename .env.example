# Copy this file to .env and fill in your values.

# --- Frontend (set in Lovable's environment variables settings) ---
# VITE_API_URL=https://your-app.up.railway.app

# --- Backend (set in Railway's environment variables settings) ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Your Lovable app URL (for CORS on the deployed backend)
# FRONTEND_URL=https://yourapp.lovable.app

# Optional: change the port the API server listens on (default: 3001)
# API_PORT=3001
